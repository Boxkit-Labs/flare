{
  "name": "flare-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "main": "dist/server.js",
  "scripts": {
    "dev": "npx tsx --watch src/server.ts",
    "build": "tsc && node -e \"const fs = require('fs'); const path = require('path'); const destDir = path.join('dist', 'db'); if (!fs.existsSync(destDir)) fs.mkdirSync(destDir, { recursive: true }); fs.copyFileSync(path.join('src', 'db', 'schema.sql'), path.join(destDir, 'schema.sql'))\"",
    "start": "node dist/server.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "*",
    "@x402/core": "^2.8.0",
    "@x402/express": "^2.8.0",
    "@x402/stellar": "^2.8.0",
    "better-sqlite3": "*",
    "cors": "*",
    "dotenv": "*",
    "express": "^5.2.1",
    "firebase-admin": "*",
    "node-cron": "*",
    "uuid": "*",
    "x402-stellar": "*"
  },
  "devDependencies": {
    "@types/better-sqlite3": "*",
    "@types/cors": "*",
    "@types/express": "*",
    "@types/node": "*",
    "@types/uuid": "*",
    "nodemon": "*",
    "ts-node": "*",
    "typescript": "*"
  }
}
